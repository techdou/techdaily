# ========================================
# TechDaily .gitignore
# ========================================

# === Secrets / Credentials ===
.env
.env.*
*.key
*.pem
credentials.json
secrets.json

# === Build Artifacts ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# === Audio (large, regenerated daily) ===
public/20??/??/??/audio.mp3

# === Runtime State ===
state.json
*.state

# === OS Files ===
.DS_Store
Thumbs.db
desktop.ini

# === Editor ===
.vscode/
.idea/
*.swp
*.swo
*~

# === Temp ===
*.tmp
*.bak
*.log
