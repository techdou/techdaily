# ========================================
# TechDaily .gitignore
# ========================================

# === Secrets / Credentials ===
.env
.env.*
*.key
*.pem
credentials.json
secrets.json
*.secret

# === API Keys / Tokens ===
*.token
*.apikey
mmx_config.json

# === Build Artifacts ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# === Runtime State ===
state.json
*.state
*.local

# === OS Files ===
.DS_Store
Thumbs.db
desktop.ini

# === Editor / IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === Temp ===
*.tmp
*.bak
*.log

# === OpenClaw Skill（含部署细节，不公开） ===
SKILL.md

# === Local Config ===
config.local.json
deploy.local.sh
